# Copy this file to .env and fill in real values. Never commit the real .env file.

# RPC endpoint for Monad mainnet.
RPC_URL=https://rpc.monad.xyz

# Private key for a DEDICATED operator wallet — do NOT reuse your admin/deployer wallet here.
# This key signs an automatic on-chain transaction (revealAndResolve) every time a bet/round
# closes, so this process must be able to do that unattended. Least-privilege: this wallet
# should hold ONLY OPERATOR_ROLE on each game contract, nothing else (no ADMIN_ROLE, no funds
# beyond what's needed for gas).
OPERATOR_PRIVATE_KEY=

# Deployed contract addresses — keep in sync with artifacts/chog-casino/src/config/contracts.ts
TREASURY_ADDRESS=0x0eCcfcD70E7AE6B4D11C86b5bF34F1e84069Ea84
COINFLIP_ADDRESS=0x533Aa6cf0D7C0a232c740a2364B6dD60c60174Cf
DICE_ADDRESS=0xA6CA2dcc13Ef28714610440f136A2789d65B07dd
ROULETTE_ADDRESS=0x4b90Bc0E486983C85F29d56C289ce90759510Eab
MINES_ADDRESS=0xa5Ac542aF5d8381a2Ee174a87D8874De2693C819
CRASH_ADDRESS=0x83B779059B82f149F86e96B04c9700bb15b45a63
BLACKJACK_ADDRESS=0x4e05B532c7bf3250979265cB096A39E1A344d3da

# HTTP port the frontend talks to (POST /commit, GET /blackjack/:roundId/cards).
PORT=8787

# Where pending/resolved server seeds are persisted. Must survive restarts — losing this file
# before a round is revealed means that round can never be settled. Back this up; for real
# production load, swap this whole module for a proper database with real backups.
SEED_STORE_PATH=./data/seeds.json

# ── Custodial deposit-address vault (optional — omit all of these to disable it) ──
# Leave every var in this section blank and the operator runs exactly as before, with no
# custodial deposit addresses offered.

# THE MOST SENSITIVE SECRET IN THIS ENTIRE SYSTEM. A BIP-39 mnemonic used to derive ONE
# permanent address per player (standard m/44'/60'/0'/0/{index} path). Anyone who has this
# phrase can derive and drain EVERY player's deposit address, not just one. Generate it with
# `cast wallet new-mnemonic` or any standard BIP-39 tool, store it somewhere far more carefully
# guarded than OPERATOR_PRIVATE_KEY above (ideally on a separate machine from this process),
# and never commit it. Rotating it means every existing deposit address changes.
DEPOSIT_MNEMONIC=

# Private key for a DEDICATED vault-operator wallet — must hold OPERATOR_ROLE on
# CustodialVault (see contracts/script/DeployCustodialVault.s.sol). Deliberately a DIFFERENT
# key from OPERATOR_PRIVATE_KEY above: a leak of one must not also compromise the other. This
# wallet also funds small MON gas top-ups so derived deposit addresses can sweep ERC20 tokens —
# keep it stocked with MON for gas, but it should never hold more than that.
VAULT_OPERATOR_PRIVATE_KEY=

# The deployed CustodialVault address — keep in sync with
# artifacts/chog-casino/src/config/contracts.ts.
CUSTODIAL_VAULT_ADDRESS=

# How often (ms) to poll every known deposit address for a new balance. Lower = funds spend
# less time sitting at the derived address before being swept, at the cost of more RPC calls.
DEPOSIT_POLL_INTERVAL_MS=20000

# Native MON (in wei) kept in a deposit address so it can pay gas to sweep an ERC20 (USDC/CHOG)
# balance out. Topped up from the vault-operator wallet automatically when needed.
DEPOSIT_GAS_RESERVE_WEI=2000000000000000

# Where deposit-address assignments and in-flight sweep records are persisted. Same durability
# requirement as SEED_STORE_PATH — back this up.
DEPOSIT_STORE_PATH=./data/deposit-addresses.json
